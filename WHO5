  { id: "7", timestamp: "2026-07-05T08:15:00.000Z", plantel: "Escuela Preparatoria No. 10", sexo: "Femenino", grado: "4° Semestre", desempeño: "Suficiente", r1: 2, r2: 2, r3: 1, r4: 0, r5: 2, score: 28, alert: true } // Alerta por <13 o item con 0
];

export default function App() {
  // Estado para la navegación interna: 'survey' | 'admin'
  const [activeTab, setActiveTab] = useState('survey');

  // Estado para las respuestas de la base de datos (iniciamos con los datos semilla)
  const [records, setRecords] = useState(() => {
    const saved = localStorage.getItem('udg_wellbeing_records');
    return saved ? JSON.parse(saved) : SEED_DATA;
  });

  // Guardar en localStorage de forma local
  useEffect(() => {
    localStorage.setItem('udg_wellbeing_records', JSON.stringify(records));
  }, [records]);

  // --- ESTADOS DE LA ENCUESTA ---
  const [plantel, setPlantel] = useState('');
  const [sexo, setSexo] = useState('');
  const [grado, setGrado] = useState('');
  const [desempeño, setDesempeño] = useState('');
  
  // Respuestas del WHO-5 (valores de 0 a 5, por defecto null para obligar a contestar)
  const [r1, setR1] = useState(null);
  const [r2, setR2] = useState(null);
  const [r3, setR3] = useState(null);
  const [r4, setR4] = useState(null);
  const [r5, setR5] = useState(null);

  const [surveySubmitted, setSurveySubmitted] = useState(false);
  const [lastCalculatedScore, setLastCalculatedScore] = useState(0);
  const [lastHadAlert, setLastHadAlert] = useState(false);
  const [formError, setFormError] = useState('');

  // --- ESTADOS DEL PANEL DE ADMINISTRACIÓN ---
  const [filterPlantel, setFilterPlantel] = useState('Todos');
  const [filterGrado, setFilterGrado] = useState('Todos');
  const [filterSexo, setFilterSexo] = useState('Todos');
  const [filterRendimiento, setFilterRendimiento] = useState('Todos');
  const [filterAlerta, setFilterAlerta] = useState('Todos'); // 'Todos' | 'Con Alerta' | 'Normal'

  // Reiniciar formulario de encuesta
  const resetForm = () => {
    setPlantel('');
    setSexo('');
    setGrado('');
    setDesempeño('');
    setR1(null);
    setR2(null);
    setR3(null);
    setR4(null);
    setR5(null);
    setSurveySubmitted(false);
    setFormError('');
  };

  // Manejar el envío de la encuesta
  const handleSubmitSurvey = (e) => {
    e.preventDefault();

    // Validar datos demográficos
    if (!plantel || !sexo || !grado || !desempeño) {
      setFormError('Por favor, completa todos los datos de tu perfil escolar.');
      return;
    }

    // Validar reactivos de bienestar
    if (r1 === null || r2 === null || r3 === null || r4 === null || r5 === null) {
      setFormError('Por favor, responde las 5 afirmaciones sobre tu bienestar emocional.');
      return;
    }

    setFormError('');

    // Calcular Puntuación del WHO-5
    // Suma de los reactivos (0 a 25) multiplicada por 4 para escala 0 a 100
    const rawSum = r1 + r2 + r3 + r4 + r5;
    const finalScore = rawSum * 4;

    // Criterio de Alerta:
    // 1. Puntuación menor a 13 (<52 en escala porcentual 100). Nota del manual: "puntuación menor que 13 (de 25) indica bajo bienestar"
    // El PDF original indica: "menor que 13" [en escala directa de 0 a 25]. El puntaje 13 de 25 equivale a 52 de 100.
    // 2. Si el alumno responde 0 o 1 en cualquiera de los 5 reactivos.
    const hasLowWellbeing = rawSum < 13;
    const hasLowItemValue = [r1, r2, r3, r4, r5].some(val => val === 0 || val === 1);
    const hasAlert = hasLowWellbeing || hasLowItemValue;

    // Crear nuevo registro
    const newRecord = {
      id: Date.now().toString(),
      timestamp: new Date().toISOString(),
      plantel,
      sexo,
      grado,
      desempeño,
      r1, r2, r3, r4, r5,
      score: finalScore,
      alert: hasAlert
    };

    setRecords(prev => [newRecord, ...prev]);
    setLastCalculatedScore(finalScore);
    setLastHadAlert(hasAlert);
    setSurveySubmitted(true);
  };

  // Eliminar un registro individual (Módulo admin)
  const handleDeleteRecord = (id) => {
    if (window.confirm('¿Estás seguro de que deseas eliminar este registro de forma permanente?')) {
      setRecords(prev => prev.filter(r => r.id !== id));
    }
  };

  // Limpiar toda la base de datos local
  const handleClearDatabase = () => {
    if (window.confirm('¡Atención! Esto borrará TODOS los registros almacenados. ¿Deseas continuar?')) {
      setRecords([]);
    }
  };

  // Restaurar datos de prueba
  const handleRestoreSeeds = () => {
    setRecords(SEED_DATA);
  };

  // --- FILTRADO DE DATOS ---
  const filteredRecords = records.filter(rec => {
    const matchPlantel = filterPlantel === 'Todos' || rec.plantel === filterPlantel;
    const matchGrado = filterGrado === 'Todos' || rec.grado === filterGrado;
    const matchSexo = filterSexo === 'Todos' || rec.sexo === filterSexo;
    const matchRendimiento = filterRendimiento === 'Todos' || rec.desempeño === filterRendimiento;
    const matchAlerta = filterAlerta === 'Todos' || 
      (filterAlerta === 'Con Alerta' && rec.alert) || 
      (filterAlerta === 'Sin Alerta' && !rec.alert);

    return matchPlantel && matchGrado && matchSexo && matchRendimiento && matchAlerta;
  });

  // --- ESTADÍSTICAS ---
  const totalRespuestas = filteredRecords.length;
  const promedioBienestar = totalRespuestas > 0 
    ? (filteredRecords.reduce((acc, r) => acc + r.score, 0) / totalRespuestas).toFixed(1)
    : 0;
  const totalAlertas = filteredRecords.filter(r => r.alert).length;
  const porcentajeAlertas = totalRespuestas > 0 
    ? ((totalAlertas / totalRespuestas) * 100).toFixed(1)
    : 0;

  // Exportar a CSV de manera local y directa
  const handleExportCSV = () => {
    if (filteredRecords.length === 0) {
      alert("No hay registros para exportar en este momento.");
      return;
    }

    // Encabezados
    const headers = [
      "ID", "Fecha/Hora", "Plantel UDG", "Sexo", "Grado", 
      "Desempeño Académico", "R1_Alegre", "R2_Tranquilo", 
      "R3_Activo", "R4_Fresco", "R5_Interes", "Suma_Cruda_WHO5", 
      "Puntaje_Final_100", "Alerta_Atencion"
    ];

    const rows = filteredRecords.map(r => {
      const sumaCruda = r.r1 + r.r2 + r.r3 + r.r4 + r.r5;
      return [
        r.id,
        new Date(r.timestamp).toLocaleString('es-MX'),
        `"${r.plantel.replace(/"/g, '""')}"`,
        r.sexo,
        r.grado,
        r.desempeño,
        r.r1,
        r.r2,
        r.r3,
        r.r4,
        r.r5,
        sumaCruda,
        r.score,
        r.alert ? "SÍ" : "NO"
      ];
    });

    const csvContent = "data:text/csv;charset=utf-8,\uFEFF" 
      + [headers.join(","), ...rows.map(e => e.join(","))].join("\n");
    
    const encodedUri = encodeURI(csvContent);
    const link = document.createElement("a");
    link.setAttribute("href", encodedUri);
    link.setAttribute("download", `Línea_Base_Bienestar_UDG_${new Date().toISOString().split('T')[0]}.csv`);
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
  };

  return (
    <div className="min-h-screen bg-slate-50 flex flex-col font-sans text-slate-800">
      {/* Header Principal - Identidad UDG */}
      <header className="bg-gradient-to-r from-red-700 via-blue-900 to-slate-900 text-white shadow-md">
        <div className="max-w-7xl mx-auto px-4 py-4 flex flex-col sm:flex-row justify-between items-center gap-4">
          <div className="flex items-center gap-3">
            <div className="bg-white p-2 rounded-lg text-red-700 font-bold text-xl shadow-inner flex items-center justify-center">
              UDG
            </div>
            <div>
              <h1 className="text-xl md:text-2xl font-bold tracking-wide">
                Línea de Bienestar Integral SEMS
              </h1>
              <p className="text-xs text-slate-300">
                Universidad de Guadalajara · Diagnóstico y Seguimiento Psicopedagógico
              </p>
            </div>
          </div>
          
          {/* Navegación Principal */}
          <div className="flex gap-2 bg-black/20 p-1 rounded-xl">
            <button
              onClick={() => { setActiveTab('survey'); resetForm(); }}
              className={`px-4 py-2 rounded-lg font-medium text-sm transition-all duration-200 flex items-center gap-2 ${
                activeTab === 'survey' 
                  ? 'bg-white text-blue-950 shadow-sm' 
                  : 'text-slate-200 hover:bg-white/10'
              }`}
            >
              <Heart className="w-4 h-4 text-red-500" />
              Aplicar Test (WHO-5)
            </button>
            <button
              onClick={() => setActiveTab('admin')}
              className={`px-4 py-2 rounded-lg font-medium text-sm transition-all duration-200 flex items-center gap-2 ${
                activeTab === 'admin' 
                  ? 'bg-white text-blue-950 shadow-sm' 
                  : 'text-slate-200 hover:bg-white/10'
              }`}
            >
              <BarChart2 className="w-4 h-4 text-blue-500" />
              Panel de Datos ({records.length})
            </button>
          </div>
        </div>
      </header>

      <main className="flex-grow max-w-7xl w-full mx-auto p-4 md:py-8">
        
        {/* ========================================================= */}
        {/* SECCIÓN 1: VISTA DE ENCUESTA PARA ALUMNOS                  */}
        {/* ========================================================= */}
        {activeTab === 'survey' && !surveySubmitted && (
          <div className="max-w-3xl mx-auto">
            {/* Banner Informativo */}
            <div className="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 mb-6">
              <div className="flex items-start gap-4">
                <div className="p-3 bg-red-50 text-red-600 rounded-xl hidden sm:block">
                  <Sparkles className="w-6 h-6" />
                </div>
                <div>
                  <span className="bg-red-100 text-red-800 text-xs font-semibold px-2.5 py-0.5 rounded-full uppercase">
                    SEMS - Salud Mental
                  </span>
                  <h2 className="text-xl font-bold text-slate-900 mt-2">
                    Tu bienestar nos importa
                  </h2>
                  <p className="text-sm text-slate-600 mt-1 leading-relaxed">
                    Este instrumento ayuda a tu escuela a conocer el nivel de bienestar emocional general de los estudiantes. 
                    Tus respuestas son confidenciales y se procesan para brindarte un mejor acompañamiento y actividades de apoyo psicopedagógico.
                  </p>
                  <p className="text-xs text-slate-400 mt-2 italic">
                    Basado en el Índice de Bienestar WHO-5 oficial de la Organización Mundial de la Salud.
                  </p>
                </div>
              </div>
            </div>

            <form onSubmit={handleSubmitSurvey} className="space-y-6">
              
              {/* Sección A: Datos Generales */}
              <div className="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                <div className="bg-blue-950 text-white px-6 py-4 flex items-center gap-2">
                  <User className="w-5 h-5 text-red-400" />
                  <h3 className="font-semibold">Sección 1: Datos de Identificación Escolar</h3>
                </div>
                
                <div className="p-6 grid grid-cols-1 md:grid-cols-2 gap-4">
                  
                  {/* Plantel */}
                  <div className="flex flex-col gap-1.5">
                    <label className="text-xs font-bold text-slate-700 uppercase tracking-wider flex items-center gap-1">
                      <School className="w-3.5 h-3.5 text-blue-700" /> Plantel / Preparatoria UDG:
                    </label>
                    <select
                      value={plantel}
                      onChange={(e) => setPlantel(e.target.value)}
                      className="w-full bg-slate-50 border border-slate-300 text-slate-800 rounded-xl px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                      required
                    >
                      <option value="">-- Selecciona tu Preparatoria --</option>
                      {PREPARATORIAS_UDG.map((prepa, index) => (
                        <option key={index} value={prepa}>{prepa}</option>
                      ))}
                    </select>
                  </div>

                  {/* Sexo */}
                  <div className="flex flex-col gap-1.5">
                    <label className="text-xs font-bold text-slate-700 uppercase tracking-wider">
                      Sexo (Asignado al nacer / Acta de nacimiento):
                    </label>
                    <div className="grid grid-cols-3 gap-2">
                      {["Femenino", "Masculino", "Otro"].map((option) => (
                        <button
                          type="button"
                          key={option}
                          onClick={() => setSexo(option)}
                          className={`py-2 px-3 text-sm font-medium rounded-xl border transition-all ${
                            sexo === option 
                              ? 'bg-blue-50 border-blue-600 text-blue-900 shadow-sm' 
                              : 'bg-white border-slate-300 text-slate-700 hover:bg-slate-50'
                          }`}
                        >
                          {option}
                        </button>
                      ))}
                    </div>
                  </div>

                  {/* Grado / Semestre */}
                  <div className="flex flex-col gap-1.5">
                    <label className="text-xs font-bold text-slate-700 uppercase tracking-wider">
                      Semestre que cursas actualmente:
                    </label>
                    <select
                      value={grado}
                      onChange={(e) => setGrado(e.target.value)}
                      className="w-full bg-slate-50 border border-slate-300 text-slate-800 rounded-xl px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                      required
                    >
                      <option value="">-- Selecciona Semestre --</option>
                      <option value="1° Semestre">1° Semestre (Primer Ingreso)</option>
                      <option value="2° Semestre">2° Semestre</option>
                      <option value="3° Semestre">3° Semestre</option>
                      <option value="4° Semestre">4° Semestre</option>
                      <option value="5° Semestre">5° Semestre</option>
                      <option value="6° Semestre">6° Semestre (Egreso)</option>
                    </select>
                  </div>

                  {/* Desempeño Académico Auto-Reportado */}
                  <div className="flex flex-col gap-1.5">
                    <label className="text-xs font-bold text-slate-700 uppercase tracking-wider flex items-center gap-1">
                      <BookOpen className="w-3.5 h-3.5 text-blue-700" /> Desempeño Académico Habitual:
                    </label>
                    <select
                      value={desempeño}
                      onChange={(e) => setDesempeño(e.target.value)}
                      className="w-full bg-slate-50 border border-slate-300 text-slate-800 rounded-xl px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                      required
                    >
                      <option value="">-- ¿Cómo consideras tu rendimiento escolar? --</option>
                      <option value="Excelente">Excelente (Normalmente 95 - 100)</option>
                      <option value="Muy Bueno">Muy Bueno (Normalmente 85 - 94)</option>
                      <option value="Bueno">Bueno (Normalmente 75 - 84)</option>
                      <option value="Suficiente">Suficiente (Normalmente 60 - 74)</option>
                      <option value="No Aprobatorio">Con dificultades / No Aprobatorio (Menor a 60)</option>
                    </select>
                  </div>

                </div>
              </div>

              {/* Sección B: WHO-5 */}
              <div className="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                <div className="bg-red-700 text-white px-6 py-4">
                  <h3 className="font-semibold flex items-center gap-2">
                    <Heart className="w-5 h-5 fill-current" /> 
                    Sección 2: Escala de Bienestar General OMS-5
                  </h3>
                  <p className="text-xs text-red-100 mt-1">
                    Por favor, selecciona para cada una de las afirmaciones la opción que define mejor **cómo te has sentido durante las últimas dos semanas**.
                  </p>
                </div>

                <div className="p-4 sm:p-6 divide-y divide-slate-100">
                  {[
                    { id: 1, text: "Me he sentido alegre y de buen humor.", val: r1, setter: setR1 },
                    { id: 2, text: "Me he sentido tranquilo y relajado.", val: r2, setter: setR2 },
                    { id: 3, text: "Me he sentido activo y enérgico.", val: r3, setter: setR3 },
                    { id: 4, text: "Me he despertado fresco y descansado.", val: r4, setter: setR4 },
                    { id: 5, text: "Mi vida cotidiana ha estado llena de cosas que me interesan.", val: r5, setter: setR5 },
                  ].map((item) => (
                    <div key={item.id} className="py-5 first:pt-0 last:pb-0">
                      <div className="mb-3">
                        <span className="text-xs font-extrabold text-red-600 uppercase tracking-widest bg-red-50 px-2 py-0.5 rounded mr-2">
                          Ítem {item.id}
                        </span>
                        <h4 className="text-base font-semibold text-slate-900 inline">
                          {item.text}
                        </h4>
                      </div>

                      {/* Escala Likert de Respuestas */}
                      <div className="grid grid-cols-2 sm:grid-cols-6 gap-2 mt-2">
                        {[
                          { text: "Todo el tiempo", points: 5 },
                          { text: "La mayor parte", points: 4 },
                          { text: "Más de la mitad", points: 3 },
                          { text: "Menos de la mitad", points: 2 },
                          { text: "De vez en cuando", points: 1 },
                          { text: "Nunca", points: 0 }
                        ].map((opt) => (
                          <button
                            type="button"
                            key={opt.points}
                            onClick={() => item.setter(opt.points)}
                            className={`p-2.5 rounded-xl border text-center transition-all flex flex-col justify-between items-center h-full gap-1.5 ${
                              item.val === opt.points
                                ? 'bg-red-50 border-red-500 text-red-950 ring-2 ring-red-200 font-semibold'
                                : 'bg-white border-slate-200 text-slate-700 hover:bg-slate-50'
                            }`}
                          >
                            <span className="text-[10px] uppercase font-bold leading-tight opacity-90">
                              {opt.text}
                            </span>
                            <span className={`w-6 h-6 rounded-full flex items-center justify-center text-xs ${
                              item.val === opt.points 
                                ? 'bg-red-600 text-white' 
                                : 'bg-slate-100 text-slate-500'
                            }`}>
                              {opt.points}
                            </span>
                          </button>
                        ))}
                      </div>
                    </div>
                  ))}
                </div>
              </div>

              {/* Mensaje de error si falta algo */}
              {formError && (
                <div className="bg-red-50 border-l-4 border-red-600 text-red-800 p-4 rounded-xl flex items-center gap-2">
                  <AlertTriangle className="w-5 h-5 text-red-600 shrink-0" />
                  <p className="text-sm font-medium">{formError}</p>
                </div>
              )}

              {/* Botón de Envío */}
              <button
                type="submit"
                className="w-full bg-gradient-to-r from-red-700 to-blue-900 text-white py-4 px-6 rounded-2xl font-bold text-lg hover:from-red-800 hover:to-blue-950 shadow-lg transform hover:-translate-y-0.5 active:translate-y-0 transition-all duration-150 flex items-center justify-center gap-2"
              >
                Enviar Respuestas Diagnósticas
                <ChevronRight className="w-5 h-5" />
              </button>

            </form>
          </div>
        )}

        {/* ========================================================= */}
        {/* SECCIÓN 1.1: PANTALLA DE ÉXITO TRAS CONTESTAR             */}
        {/* ========================================================= */}
        {activeTab === 'survey' && surveySubmitted && (
          <div className="max-w-2xl mx-auto bg-white rounded-3xl shadow-xl border border-slate-200 overflow-hidden text-center p-8 md:p-12">
            <div className="inline-flex p-4 bg-emerald-100 text-emerald-600 rounded-full mb-6">
              <CheckCircle className="w-16 h-16" />
            </div>

            <h2 className="text-3xl font-black text-slate-900 mb-2">
              ¡Muchas gracias por participar!
            </h2>
            <p className="text-slate-600 max-w-md mx-auto text-sm md:text-base">
              Tus respuestas han sido registradas con éxito en el sistema diagnóstico de Bienestar Integral de la UDG.
            </p>

            <div className="my-8 p-6 bg-slate-50 rounded-2xl max-w-md mx-auto border border-slate-100 text-left">
              <h3 className="text-xs font-bold text-slate-500 uppercase tracking-wider text-center mb-4">
                Información del Registro Realizado
              </h3>
              
              <div className="space-y-2.5 text-sm">
                <div className="flex justify-between border-b border-slate-200 pb-1.5">
                  <span className="text-slate-500">Preparatoria:</span>
                  <span className="font-semibold text-slate-800 truncate max-w-[250px]">{plantel}</span>
                </div>
                <div className="flex justify-between border-b border-slate-200 pb-1.5">
                  <span className="text-slate-500">Grado / Sexo:</span>
                  <span className="font-semibold text-slate-800">{grado} ({sexo})</span>
                </div>
                <div className="flex justify-between pb-1.5">
                  <span className="text-slate-500">Auto-percepción académica:</span>
                  <span className="font-semibold text-slate-800">{desempeño}</span>
                </div>
              </div>
            </div>

            <p className="text-xs text-slate-400 max-w-sm mx-auto mb-8 leading-relaxed">
              La información recolectada se almacena de forma local para propósitos de análisis psicopedagógicos de tu plantel escolar.
            </p>

            <div className="flex flex-col sm:flex-row gap-3 justify-center">
              <button
                onClick={resetForm}
                className="px-6 py-3 bg-slate-100 hover:bg-slate-200 text-slate-800 rounded-xl font-bold transition-all text-sm"
              >
                Aplicar otra encuesta
              </button>
              <button
                onClick={() => { setActiveTab('admin'); }}
                className="px-6 py-3 bg-blue-900 hover:bg-blue-950 text-white rounded-xl font-bold transition-all text-sm flex items-center justify-center gap-2"
              >
                Ir al Panel Admin
                <ChevronRight className="w-4 h-4" />
              </button>
            </div>
          </div>
        )}

        {/* ========================================================= */}
        {/* SECCIÓN 2: PANEL DE CONTROL ADMINISTRADOR                  */}
        {/* ========================================================= */}
        {activeTab === 'admin' && (
          <div className="space-y-6">
            
            {/* Cabecera del Panel */}
            <div className="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
              <div>
                <h2 className="text-2xl font-bold text-slate-950 flex items-center gap-2">
                  <BarChart2 className="w-7 h-7 text-blue-800" />
                  Módulo de Análisis y Base de Datos
                </h2>
                <p className="text-xs text-slate-500 mt-1">
                  Monitoreo de la línea base de bienestar integral en preparatorias de la UDG.
                </p>
              </div>

              {/* Acciones del Administrador */}
              <div className="flex flex-wrap gap-2 w-full md:w-auto">
                <button
                  onClick={handleExportCSV}
                  className="bg-emerald-700 hover:bg-emerald-800 text-white px-4 py-2 rounded-xl text-sm font-semibold flex items-center gap-1.5 shadow-sm transition-all flex-grow md:flex-grow-0 justify-center"
                >
                  <Download className="w-4 h-4" />
                  Exportar Base (CSV)
                </button>
                <button
                  onClick={handleRestoreSeeds}
                  className="bg-blue-100 hover:bg-blue-200 text-blue-800 px-4 py-2 rounded-xl text-sm font-semibold flex items-center gap-1.5 transition-all flex-grow md:flex-grow-0 justify-center"
                  title="Cargar registros de ejemplo para pruebas"
                >
                  Cargar Semilla
                </button>
                <button
                  onClick={handleClearDatabase}
                  className="bg-red-50 hover:bg-red-100 text-red-700 px-4 py-2 rounded-xl text-sm font-semibold flex items-center gap-1.5 transition-all flex-grow md:flex-grow-0 justify-center"
                >
                  <Trash2 className="w-4 h-4" />
                  Limpiar BD
                </button>
              </div>
            </div>

            {/* Fila de Tarjetas de Estadísticas */}
            <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
              
              {/* Total Alumnos */}
              <div className="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm flex items-center gap-4">
                <div className="p-3.5 bg-blue-50 text-blue-700 rounded-2xl">
                  <Users className="w-6 h-6" />
                </div>
                <div>
                  <p className="text-xs font-bold text-slate-400 uppercase tracking-wider">Total de Muestras</p>
                  <p className="text-3xl font-black text-slate-900">{totalRespuestas}</p>
                </div>
              </div>

              {/* Promedio de Bienestar UDG */}
              <div className="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm flex items-center gap-4">
                <div className="p-3.5 bg-teal-50 text-teal-700 rounded-2xl">
                  <TrendingUp className="w-6 h-6" />
                </div>
                <div>
                  <p className="text-xs font-bold text-slate-400 uppercase tracking-wider">Promedio de Bienestar</p>
                  <div className="flex items-baseline gap-1">
                    <p className="text-3xl font-black text-slate-900">{promedioBienestar}</p>
                    <span className="text-xs text-slate-500">/ 100</span>
                  </div>
                </div>
              </div>

              {/* Casos en Alerta */}
              <div className="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm flex items-center gap-4">
                <div className={`p-3.5 rounded-2xl ${totalAlertas > 0 ? 'bg-red-50 text-red-600' : 'bg-slate-100 text-slate-500'}`}>
                  <AlertTriangle className="w-6 h-6" />
                </div>
                <div>
                  <p className="text-xs font-bold text-slate-400 uppercase tracking-wider">Casos en Alerta</p>
                  <p className={`text-3xl font-black ${totalAlertas > 0 ? 'text-red-600' : 'text-slate-900'}`}>
                    {totalAlertas}
                  </p>
                </div>
              </div>

              {/* Porcentaje de Riesgo */}
              <div className="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm flex items-center gap-4">
                <div className={`p-3.5 rounded-2xl ${totalAlertas > 0 ? 'bg-amber-50 text-amber-600' : 'bg-slate-100 text-slate-500'}`}>
                  <Heart className="w-6 h-6" />
                </div>
                <div>
                  <p className="text-xs font-bold text-slate-400 uppercase tracking-wider">% Sugerido de Atención</p>
                  <p className={`text-3xl font-black ${totalAlertas > 0 ? 'text-amber-600' : 'text-slate-900'}`}>
                    {porcentajeAlertas}%
                  </p>
                </div>
              </div>

            </div>

            {/* Módulo de Filtros de la Base de Datos */}
            <div className="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
              <h3 className="text-sm font-bold text-slate-900 uppercase tracking-wider flex items-center gap-2 mb-4">
                <Filter className="w-4 h-4 text-blue-900" />
                Filtros de Segmentación
              </h3>
              
              <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3">
                
                {/* Filtro Plantel */}
                <div>
                  <label className="block text-xs font-semibold text-slate-500 mb-1">Plantel / Prepa:</label>
                  <select 
                    value={filterPlantel} 
                    onChange={(e) => setFilterPlantel(e.target.value)}
                    className="w-full bg-slate-50 border border-slate-200 rounded-lg p-2 text-xs"
                  >
                    <option value="Todos">Todos ({records.length})</option>
                    {Array.from(new Set(records.map(r => r.plantel))).map((p, idx) => (
                      <option key={idx} value={p}>{p}</option>
                    ))}
                  </select>
                </div>

                {/* Filtro Grado */}
                <div>
                  <label className="block text-xs font-semibold text-slate-500 mb-1">Semestre:</label>
                  <select 
                    value={filterGrado} 
                    onChange={(e) => setFilterGrado(e.target.value)}
                    className="w-full bg-slate-50 border border-slate-200 rounded-lg p-2 text-xs"
                  >
                    <option value="Todos">Todos</option>
                    <option value="1° Semestre">1° Semestre</option>
                    <option value="2° Semestre">2° Semestre</option>
                    <option value="3° Semestre">3° Semestre</option>
                    <option value="4° Semestre">4° Semestre</option>
                    <option value="5° Semestre">5° Semestre</option>
                    <option value="6° Semestre">6° Semestre</option>
                  </select>
                </div>

                {/* Filtro Sexo */}
                <div>
                  <label className="block text-xs font-semibold text-slate-500 mb-1">Sexo:</label>
                  <select 
                    value={filterSexo} 
                    onChange={(e) => setFilterSexo(e.target.value)}
                    className="w-full bg-slate-50 border border-slate-200 rounded-lg p-2 text-xs"
                  >
                    <option value="Todos">Todos</option>
                    <option value="Femenino">Femenino</option>
                    <option value="Masculino">Masculino</option>
                    <option value="Otro">Otro</option>
                  </select>
                </div>

                {/* Filtro Rendimiento Académico */}
                <div>
                  <label className="block text-xs font-semibold text-slate-500 mb-1">Desempeño Académico:</label>
                  <select 
                    value={filterRendimiento} 
                    onChange={(e) => setFilterRendimiento(e.target.value)}
                    className="w-full bg-slate-50 border border-slate-200 rounded-lg p-2 text-xs"
                  >
                    <option value="Todos">Todos</option>
                    <option value="Excelente">Excelente</option>
                    <option value="Muy Bueno">Muy Bueno</option>
                    <option value="Bueno">Bueno</option>
                    <option value="Suficiente">Suficiente</option>
                    <option value="No Aprobatorio">Con dificultades</option>
                  </select>
                </div>

                {/* Filtro de Alerta */}
                <div>
                  <label className="block text-xs font-semibold text-slate-500 mb-1">Estatus Clínico/Alerta:</label>
                  <select 
                    value={filterAlerta} 
                    onChange={(e) => setFilterAlerta(e.target.value)}
                    className="w-full bg-slate-50 border border-slate-200 rounded-lg p-2 text-xs"
                  >
                    <option value="Todos">Todos</option>
                    <option value="Con Alerta">Alerta de Atención (Sugerida Depresión)</option>
                    <option value="Sin Alerta">Normal</option>
                  </select>
                </div>

              </div>
            </div>

            {/* Tabla Principal de Datos */}
            <div className="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
              <div className="bg-slate-900 text-white px-6 py-4 flex justify-between items-center">
                <span className="font-semibold text-sm">
                  Base de Datos Línea Base (Mostrando {filteredRecords.length} de {records.length} registros)
                </span>
                <span className="text-xs bg-white/20 px-2 py-0.5 rounded-md font-bold text-slate-200">
                  UDG-SEMS
                </span>
              </div>

              {filteredRecords.length === 0 ? (
                <div className="p-12 text-center text-slate-400">
                  <FileSpreadsheet className="w-12 h-12 mx-auto text-slate-300 mb-2" />
                  <p className="font-semibold">No se encontraron registros para mostrar</p>
                  <p className="text-xs mt-1">Prueba cambiando los criterios del filtro de segmentación.</p>
                </div>
              ) : (
                <div className="overflow-x-auto">
                  <table className="w-full text-left border-collapse text-xs">
                    <thead>
                      <tr className="bg-slate-50 border-b border-slate-200 text-slate-500 font-bold uppercase tracking-wider">
                        <th className="p-3 text-center">Estatus</th>
                        <th className="p-3">Fecha</th>
                        <th className="p-3">Preparatoria / Plantel</th>
                        <th className="p-3">Grado</th>
                        <th className="p-3">Sexo</th>
                        <th className="p-3">Desempeño Académico</th>
                        <th className="p-3 text-center">Respuestas (R1-R5)</th>
                        <th className="p-3 text-center">Suma</th>
                        <th className="p-3 text-center">Score %</th>
                        <th className="p-3 text-center">Acciones</th>
                      </tr>
                    </thead>
                    <tbody className="divide-y divide-slate-100">
                      {filteredRecords.map((rec) => {
                        const sumaCruda = rec.r1 + rec.r2 + rec.r3 + rec.r4 + rec.r5;
                        return (
                          <tr key={rec.id} className="hover:bg-slate-50/80 transition-colors">
                            {/* Estatus Semáforo de Riesgo */}
                            <td className="p-3 text-center">
                              {rec.alert ? (
                                <span className="inline-flex items-center gap-1 bg-red-100 text-red-800 font-bold px-2 py-0.5 rounded-full" title="Riesgo Clínico: Se sugiere administrar el inventario de depresión ICD-10">
                                  🚨 ALERTA
                                </span>
                              ) : (
                                <span className="inline-flex items-center gap-1 bg-emerald-100 text-emerald-800 font-bold px-2 py-0.5 rounded-full">
                                  🟢 Estable
                                </span>
                              )}
                            </td>
                            {/* Fecha */}
                            <td className="p-3 text-slate-600 whitespace-nowrap">
                              {new Date(rec.timestamp).toLocaleDateString('es-MX')}
                            </td>
                            {/* Plantel */}
                            <td className="p-3 font-semibold text-slate-900 truncate max-w-[200px]" title={rec.plantel}>
                              {rec.plantel}
                            </td>
                            {/* Grado */}
                            <td className="p-3 text-slate-700">{rec.grado}</td>
                            {/* Sexo */}
                            <td className="p-3 text-slate-700">{rec.sexo}</td>
                            {/* Desempeño Académico */}
                            <td className="p-3">
                              <span className={`px-2 py-0.5 rounded-md font-semibold ${
                                rec.desempeño === 'Excelente' || rec.desempeño === 'Muy Bueno'
                                  ? 'bg-blue-50 text-blue-700'
                                  : rec.desempeño === 'Bueno'
                                  ? 'bg-slate-100 text-slate-700'
                                  : 'bg-amber-50 text-amber-700'
                              }`}>
                                {rec.desempeño}
                              </span>
                            </td>
                            {/* Respuestas R1 a R5 */}
                            <td className="p-3 text-center font-mono tracking-wider text-slate-500 whitespace-nowrap">
                              [{rec.r1}, {rec.r2}, {rec.r3}, {rec.r4}, {rec.r5}]
                            </td>
                            {/* Suma Directa */}
                            <td className="p-3 text-center font-bold text-slate-700">{sumaCruda} / 25</td>
                            {/* Score Final (Suma x 4) */}
                            <td className="p-3 text-center">
                              <span className={`font-bold text-sm ${rec.alert ? 'text-red-700' : 'text-slate-900'}`}>
                                {rec.score}
                              </span>
                            </td>
                            {/* Acciones */}
                            <td className="p-3 text-center">
                              <button
                                onClick={() => handleDeleteRecord(rec.id)}
                                className="text-red-500 hover:text-red-700 hover:bg-red-50 p-1.5 rounded-lg transition-colors"
                                title="Eliminar este registro"
                              >
                                <Trash2 className="w-4 h-4" />
                              </button>
                            </td>
                          </tr>
                        );
                      })}
                    </tbody>
                  </table>
                </div>
              )}
            </div>

            {/* Nota Técnica de Interpretación Oficial (OMS) */}
            <div className="bg-slate-100 p-6 rounded-2xl border border-slate-200">
              <h4 className="font-bold text-slate-900 flex items-center gap-2 mb-2">
                <AlertTriangle className="w-5 h-5 text-amber-600" />
                Guía de Interpretación del WHO-5 en las Preparatorias UDG:
              </h4>
              <ul className="list-disc list-inside space-y-2 text-xs text-slate-600 pl-2">
                <li>
                  <strong>Puntuación en base 100:</strong> Se obtiene sumando el puntaje obtenido en los 5 ítems (0 a 25) y multiplicando por 4.
                </li>
                <li>
                  <strong>Criterio de Riesgo Clínico:</strong> Se recomienda aplicar un inventario complementario como el <strong>"Major Depression Inventory (ICD-10)"</strong> si el alumno presenta:
                  <ul className="list-circle list-inside pl-4 mt-1 space-y-1">
                    <li>Un puntaje menor a 13 en su suma cruda (equivalente a una puntuación porcentual final menor a 52).</li>
                    <li>O si responde <strong>0 o 1 (Nunca o De vez en cuando)</strong> en cualquiera de las 5 afirmaciones presentadas.</li>
                  </ul>
                </li>
                <li>
                  <strong>Seguimiento de Cambios:</strong> Una diferencia de ±10% en el puntaje de un estudiante a lo largo del tiempo indica un cambio clínicamente significativo en su bienestar.
                </li>
              </ul>
            </div>

          </div>
        )}

      </main>

      <footer className="bg-slate-900 text-slate-400 text-center py-6 border-t border-slate-800 text-xs mt-12">
        <p>© {new Date().getFullYear()} - Sistema de Registro de Bienestar Integral UDG</p>
        <p className="mt-1">Implementado según los reactivos oficiales de la Organización Mundial de la Salud (WHO-5, Versión 1998).</p>
      </footer>
    </div>
  );
}
